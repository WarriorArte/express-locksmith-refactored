Options -Indexes
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase __BASE_PATH__

  # Dedicated installer entrypoint (easy to delete after first production setup)
  RewriteRule ^install/?$ backend/install/index.php [L,QSA,NC]

  # Laravel backend entrypoints (legacy API under /api/*.php)
  RewriteRule ^api(/.*)?$ backend/public/index.php [L,QSA,NC]
  RewriteRule ^up/?$ backend/public/index.php [L,QSA,NC]

  RewriteRule ^index\.html$ - [L]
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteCond %{REQUEST_FILENAME} !-l
  RewriteRule . __INDEX_TARGET__ [L]
</IfModule>
