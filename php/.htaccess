Options -Indexes
<IfModule mod_rewrite.c>
	RewriteEngine On
	RewriteBase /cerrajer-a-express/
	# Installer shortcut: allow /php/install
	RewriteRule ^php/install/?$ /cerrajer-a-express/php/install/ [L,R=302,NC]
	# Never rewrite backend routes to SPA
	RewriteRule ^php/ - [L,NC]
	RewriteRule ^index\.html$ - [L]
	RewriteCond %{REQUEST_FILENAME} !-f
	RewriteCond %{REQUEST_FILENAME} !-d
	RewriteCond %{REQUEST_FILENAME} !-l
	RewriteRule . /cerrajer-a-express/index.html [L]
</IfModule>
